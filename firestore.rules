rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers: scope recordings/loops to the song they belong to.
    function songData(songId) {
      return get(/databases/$(database)/documents/songs/$(songId)).data;
    }
    function ownsSong(songId) {
      return songData(songId).ownerId == request.auth.uid;
    }
    function canAccessSong(songId) {
      let s = songData(songId);
      return s.ownerId == request.auth.uid
        || request.auth.uid in s.get('sharedWith', [])
        || request.auth.uid in s.get('sharedReadOnly', [])
        || s.get('publicToken', null) != null;
    }

    match /songs/{songId} {
      allow read, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow read: if request.auth != null
        && request.auth.uid in resource.data.sharedWith;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.sharedWith
        && request.resource.data.ownerId    == resource.data.ownerId
        && request.resource.data.sharedWith == resource.data.sharedWith;
      allow read: if request.auth != null
        && request.auth.uid in resource.data.get('sharedReadOnly', []);
      allow get: if resource.data.publicToken != null;
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // ── CHANGED: was `allow read, write: if request.auth != null` ──
    // Now: read if it's yours or a song shared with you; write only if you own the song.
    // The `songId != ''` guards keep the rule from erroring on a missing/blank songId
    // (it cleanly denies instead).
    match /voice_takes/{doc} {
      allow read: if request.auth != null
        && (resource.data.get('userId', '') == request.auth.uid
            || (resource.data.get('songId', '') != '' && canAccessSong(resource.data.songId)));
      allow create: if request.auth != null
        && request.resource.data.get('songId', '') != ''
        && ownsSong(request.resource.data.songId);
      allow update, delete: if request.auth != null
        && resource.data.get('songId', '') != ''
        && ownsSong(resource.data.songId);
    }
    match /voice_trash/{doc} {
      allow read: if request.auth != null
        && (resource.data.get('userId', '') == request.auth.uid
            || (resource.data.get('songId', '') != '' && canAccessSong(resource.data.songId)));
      allow create: if request.auth != null
        && request.resource.data.get('songId', '') != ''
        && ownsSong(request.resource.data.songId);
      allow update, delete: if request.auth != null
        && resource.data.get('songId', '') != ''
        && ownsSong(resource.data.songId);
    }
    match /song_loops/{loopId} {
      allow read: if request.auth != null
        && (resource.data.get('userId', '') == request.auth.uid
            || (resource.data.get('songId', '') != '' && canAccessSong(resource.data.songId)));
      allow create: if request.auth != null
        && request.resource.data.get('songId', '') != ''
        && ownsSong(request.resource.data.songId);
      allow update, delete: if request.auth != null
        && resource.data.get('songId', '') != ''
        && ownsSong(resource.data.songId);
    }

    match /saved_beats/{beatId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
    match /analytics_events/{eventId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && request.auth.uid == 'FMskbD7caYYHdpnHRT4Vw41vqNf2';
      allow update, delete: if false;
    }
    match /error_logs/{logId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && request.auth.uid == 'FMskbD7caYYHdpnHRT4Vw41vqNf2';
      allow update, delete: if false;
    }
    match /admin_alerts/{alertId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null && request.auth.uid == 'FMskbD7caYYHdpnHRT4Vw41vqNf2';
      allow update, delete: if false;
    }
  }
}
