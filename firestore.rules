rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Songs collection — any authenticated user can read/write.
    // This matches the previous single-password behaviour: if you're in, you're in.
    match /songs/{songId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
